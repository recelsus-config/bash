#!/usr/bin/env bash
set -euo pipefail

ai_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
services_dir="${ai_root}/services"

show_usage() {
  cat <<'USAGE'
Usage: ai <command> [options] [args]

Commands:
  commit            Generate a commit message from staged diff
  diff              Review piped diff content, o' `git diff` when stdin is empty
  doc               Produce focused docs fo' a snippet (use --full fo' full mode)
  question (q)      Ask a free-fo'm question (stdin o' args)
  translate (t, trans)
                    Translate text; use --to <lang> to choose target
  cmd               Suggest o' convert commands; use --to win|cmd|ps fo' Windows
  providers         Show configured AI providers, models, and local CLI paths

Flags:
  -h, --help        Show this help
  -m, --model <model>
                    Model override
  --to <target>     Target language fo' translate, target shell fo' cmd
  -l, --language <lang>
                    Language override fo' supported commands (commit/doc/diff/question/translate)
  -p, --provider <provider>
                    AI provider (gemini, chatgpt, codex-cli, gemini-cli)

Environment:
  DEFAULT_AI_PROVIDER
                    Default provider when -p/--provider is omitted
  GEMINI_MODEL      Default model fo' gemini/gemini-cli; required fo' gemini unless -m/--model is passed
  OPENAI_MODEL      Default model fo' chatgpt; required fo' chatgpt unless -m/--model is passed
  CODEX_CLI_MODEL   Default model fo' codex-cli

Examples:
  ai commit
  ai commit -i logo.png -id images/
  ai commit --prompt "Mention README.md only as changed"
  ai doc -l jpn "function foo() { }"
  ai doc --full -l jpn "function foo() { }"
  git diff | ai diff
  ai translate --to de 'test text'
  ai cmd "./README.mdの中身を確認するには？"
  ai cmd 'ls -la' --to ps
  ai providers
USAGE
}

main() {
  if [ "$#" -eq 0 ]; then
    show_usage
    exit 1
  fi

  case "$1" in
    -h|--help|help)
      show_usage
      return 0
      ;;
  esac

  local command="$1"
  shift

  local command_args=("$@")
  local script_name=""

  local raw_arg
  if [ ${#command_args[@]} -gt 0 ]; then
    for raw_arg in "${command_args[@]}"; do
      if [ "$raw_arg" = "--mode" ]; then
        printf "[FAIL] --mode has been removed. Use ai doc --full fo' full docs.\n" >&2
        exit 1
      fi
    done
  fi

  case "$command" in
    commit)
      script_name="ai-commit.sh"
      ;;
    diff)
      script_name="ai-diff.sh"
      ;;
    doc)
      local use_full=0
      local filtered=()
      local idx=0
      local total=${#command_args[@]}
      while [ $idx -lt "$total" ]; do
        local arg="${command_args[$idx]}"
        case "$arg" in
          --full)
            use_full=1
            idx=$((idx + 1))
            continue
            ;;
          *)
            filtered+=("$arg")
            idx=$((idx + 1))
            continue
            ;;
        esac
      done

      if [ "$use_full" -eq 1 ]; then
        script_name="ai-doc-full.sh"
      else
        script_name="ai-doc.sh"
      fi

      if [ ${#filtered[@]} -gt 0 ]; then
        command_args=("${filtered[@]}")
      else
        command_args=()
      fi
      ;;
    question|q)
      script_name="ai-question.sh"
      ;;
    translate|t|trans)
      script_name="ai-translate.sh"
      ;;
    cmd)
      script_name="ai-cmd.sh"
      ;;
    providers)
      script_name="ai-providers.sh"
      ;;
    *)
      printf "[FAIL] Unknown command: %s\n" "$command" >&2
      show_usage >&2
      exit 1
      ;;
  esac

  if [ ${#command_args[@]} -gt 0 ]; then
    set -- "${command_args[@]}"
  else
    set --
  fi

  local target="${services_dir}/${script_name}"

  if [ ! -x "$target" ]; then
    printf "[FAIL] Service not executable: %s\n" "$script_name" >&2
    exit 1
  fi

  exec "$target" "$@"
}

main "$@"
